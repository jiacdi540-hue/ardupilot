# hw definition file for URMOUKY H743 (Drone H7 Flight Controller)

# MCU class and specific type
MCU STM32H7xx STM32H743xx

# board ID for firmware load
APJ_BOARD_ID AP_HW_URMOUKY_H743
undef AP_BOOTLOADER_FLASHING_ENABLED

# crystal frequency, setup to use external oscillator
OSCILLATOR_HZ 8000000

FLASH_SIZE_KB 2048

# bootloader takes first sector
FLASH_RESERVE_START_KB 384

# ChibiOS system timer
STM32_ST_USE_TIMER 5

I2C_ORDER I2C1

define HAL_STORAGE_SIZE 15360
STORAGE_FLASH_PAGE 1

# USB
PA11 OTG_FS_DM OTG1
PA12 OTG_FS_DP OTG1

# SPI1 - Primary Gyro (MPU6500/6000)
PA5 SPI1_SCK SPI1
PA6 SPI1_MISO SPI1
PA7 SPI1_MOSI SPI1

# SPI3 - Secondary Gyro
PB3 SPI3_SCK SPI3
PB4 SPI3_MISO SPI3
PB5 SPI3_MOSI SPI3

# CS pins using GYRO naming 
PC4 GYRO1_CS CS
PE2 GYRO2_CS CS

# Beeper
PA15 BUZZER OUTPUT GPIO(80) LOW

# LEDs
PE3 LED1 OUTPUT LOW GPIO(89)
PE4 LED2 OUTPUT LOW GPIO(90)

# order of UARTs (and USB)
SERIAL_ORDER OTG1 USART1 USART2 USART6

# UARTs
PA9 USART1_TX USART1
PA10 USART1_RX USART1

PA2 USART2_TX USART2
PA3 USART2_RX USART2

PC6 USART6_TX USART6
PC7 USART6_RX USART6

# I2C - Baro
PB6 I2C1_SCL I2C1
PB7 I2C1_SDA I2C1

# ADC - use correct ADC types for H743
PC0 BATT_VOLTAGE_SENS ADC1 SCALE(1)
PC1 BATT_CURRENT_SENS ADC2 SCALE(1)

# PWM outputs - 4 motor outputs
B00 TIM3_CH3 TIM3_UP
B01 TIM3_CH4 TIM3_UP
A00 TIM2_CH1 TIM2_UP
A01 TIM2_CH2 TIM2_UP

# Primary IMU on SPI1 using GYRO1_CS
SPIDEV imu1 SPI1 DEVID1 GYRO1_CS MODE3 1*MHZ 16*MHZ
IMU Invensensev3 SPI:imu1 ROTATION_ROLL_180_YAW_270

# Secondary IMU on SPI3 using GYRO2_CS
SPIDEV imu2 SPI3 DEVID2 GYRO2_CS MODE3 1*MHZ 16*MHZ
IMU Invensensev3 SPI:imu2 ROTATION_PITCH_180_YAW_270
